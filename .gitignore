# Ignore everything by default
*
*/

# Keep configuration directories
!.gitignore
!waybar/
!hypr/
!theme/
!kitty/
!waypaper/
!rofi/
!swaync/
!wallust/
!gtk-3.0/
!gtk-4.0/
!zsh/

# Keep config files in tracked directories
!waybar/**
!hypr/**
!theme/**
!kitty/**
!waypaper/**
!rofi/**
!swaync/**
!wallust/**
!gtk-3.0/**
!gtk-4.0/**
!zsh/**

# Ignore generated zsh runtime files
zsh/.zcompdump*
zsh/.zsh_history