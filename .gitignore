# Ignore everything by default
*
*/

# Keep configuration directories
!.gitignore
!CLAUDE.md
!README.md
!ARCHITECTURE.md
!ROADMAP.md
!HOWTO.md
!update.sh
!install.sh
!sync-private.sh
!packages.txt
!.hermes/
!hypr/
!theme/
!kitty/
!wallpapers/
!gtk-3.0/
!gtk-4.0/
!zsh/
!noctalia/
!noctalia/**
!yazi/
!macos/
!git/
!tmux/
!nvim/
!librewolf/
!librewolf/policies.json

# Keep config files in tracked directories
!.hermes/**
!hypr/**
!theme/**
!kitty/**
!wallpapers/**
!gtk-3.0/**
!gtk-4.0/**
!zsh/**
!noctalia/**
!yazi/**
!macos/**
!git/**
!tmux/**
!nvim/**

# Ignore generated zsh runtime files
zsh/.zcompdump*
zsh/.zsh_history

# Ignore editor/backup files anywhere in the tree
**/*.bak
