[global]
    # Appearance
    font = JetBrainsMono Nerd Font 11
    
    # Position
    origin = top-right
    offset = (10, 10)
    
    # Size
    width = (0, 350)
    height = (0, 150)
    notification_limit = 0
    
    # Progress bar
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    
    # Behavior
    indicate_hidden = yes
    shrink = no
    transparency = 0
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    frame_width = 2
    frame_color = "#89b4fa"
    separator_color = frame
    sort = yes
    idle_threshold = 120
    
    # Text
    format = "<b>%s</b>\n%b\n<small><i>%a</i></small>"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    
    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_path = /usr/share/icons/Papirus-Dark/48x48/status:/usr/share/icons/Papirus-Dark/48x48/devices:/usr/share/icons/Papirus-Dark/48x48/apps
    
    # History
    sticky_history = yes
    history_length = 100
    
    # Mouse
    mouse_left_click = do_action, close_current
    mouse_middle_click = close_current
    mouse_right_click = close_all
    
    # Misc
    dmenu = rofi -dmenu -p dunst:
    browser = firefox
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 10
    ignore_dbusclose = false
    force_xwayland = false
    force_xinerama = false

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#45475a"
    timeout = 3

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0

# App-specific rules
[discord]
    appname = discord
    frame_color = "#5865f2"
    timeout = 3

[Discord]
    appname = Discord
    frame_color = "#5865f2"
    timeout = 3

[spotify]
    appname = Spotify
    frame_color = "#1db954"
    timeout = 5

[volume]
    appname = volume
    timeout = 2

[brightness]
    appname = brightness
    timeout = 2
