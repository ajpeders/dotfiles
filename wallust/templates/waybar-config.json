{
    // ============================================
    // General Settings
    // ============================================
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,
    "expand-left": true,
    "fixed-center": true,

    // ============================================
    // Module Layout
    // ============================================
    "modules-left": ["hyprland/workspaces", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": [
        "group/media",
        "temperature",
        // "disk",
        // "memory",
        // "network",
        "custom/weather",
        "tray",
        "custom/swaync"
    ],

    // ============================================
    // Left Modules
    // ============================================
    "tray": {
        "icon-size": 16,
        "spacing": 8,
        "show-passive-items": true
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "A",
            "2": "S",
            "3": "D",
            "4": "F",
            "5": "G",
            "6": "H",
            "7": "J",
            "8": "8",
            "9": "9",
            "10": "0"
        },
        "on-click": "activate",
        "active-only": false
    },

    "hyprland/window": {
        "format": "{title}",
        "icon": true,
        "icon-size": 16,
        "max-length": 500,
        "separate-outputs": true
    },

    // ============================================
    // Center Modules
    // ============================================
    "clock": {
        "interval": 1,
        "format": "{:%a %b %d  %I:%M:%S %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='{{color4}}'><b>{}</b></span>",
                "days": "<span color='{{foreground}}'>{}</span>",
                "weekdays": "<span color='{{color3}}'><b>{}</b></span>",
                "today": "<span color='{{color2}}'><b><u>{}</u></b></span>"
            }
        }
    },

    "custom/weather": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "interval": 1800
    },

    "group/media": {
        "orientation": "horizontal",
        "modules": ["mpris", "pulseaudio"]
    },

    // ============================================
    // Right Modules - Media
    // ============================================
    "mpris": {
        "format": "[Now] {dynamic}",
        "format-paused": "[Pause] {dynamic}",
        "format-stopped": "",
        "dynamic-order": ["title", "artist"],
        "dynamic-separator": " - ",
        "player": "playerctld",
        "max-length": 72,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{player}: {title} - {artist}\n{album}"
    },

    // ============================================
    // Right Modules - Status Group
    // ============================================
    "group/status": {
        "orientation": "horizontal",
        "modules": ["network", "pulseaudio", "clock"]
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰅶",
            "deactivated": "󰾪"
        },
        "tooltip-format-activated": "Idle inhibitor active",
        "tooltip-format-deactivated": "Idle inhibitor inactive"
    },

    "custom/swaync": {
        "tooltip-format": "Left: Notifications\nRight: Do not disturb",
        "format": "{icon}",
        "format-icons": {
            "notification": "󰂚",
            "none": "󰂜",
            "dnd-notification": "󰂛",
            "dnd-none": "󰪑",
            "inhibited-notification": "󰂛",
            "inhibited-none": "󰪑",
            "dnd-inhibited-notification": "󰂛",
            "dnd-inhibited-none": "󰪑"
        },
        "return-type": "json",
        "exec-if": "command -v swaync-client >/dev/null 2>&1",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },

    // ============================================
    // System Monitoring
    // ============================================
    "cpu": {
        "interval": 2,
        "format": "易 {usage}%",
        "tooltip": true,
        "tooltip-format": "Intel(R) Core(TM) i7-8700K CPU @ 3.70GHz\nUsage: {usage}%\nLoad: {load}"
    },

    "memory": {
        "interval": 5,
        "format": "󰍛 {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },

    "disk": {
        "interval": 30,
        "format": "󰋊 {percentage_used}%",
        "path": "/",
        "tooltip-format": "Used: {used} / {total}\nFree: {free} ({percentage_free}%)"
    },

    "custom/gpu": {
        "format": "󰍹 {}",
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "return-type": "json",
        "interval": 5
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°C",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "Temperature: {temperatureC}°C"
    },

    // ============================================
    // Hardware Controls
    // ============================================
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "pulseaudio": {
        "format": "Vol {volume}%",
        "format-muted": "Vol Off",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    // ============================================
    // Network
    // ============================================
    "network": {
        "format-wifi": "WiFi {signalStrength}%",
        "format-ethernet": "Ethernet",
        "format-disconnected": "Offline",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    }
}
