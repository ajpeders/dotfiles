   \"modules-center\": [\"clock\"],\n    \"modules-right\": [\"mpris\", \"group/status\"],\n\n    \"hyprland/workspaces\": {\n        \"format\": \"{id}\",\n        \"on-click\": \"activate\",\n        \"persistent-workspaces\": {\n            \"*\": 5\n        }\n    },\n    \n    \"hyprland/window\": {\n        \"format\": \"{title}\",\n        \"icon\": true,\n        \"icon-size\": 16,\n        \"max-length\": 500,\n        \"separate-outputs\": true\n    },\n    \n    \"clock\": {\n        \"interval\": 1,\n        \"format\": \"{:%a %b %d  %I:%M:%S %p}\",\n        \"tooltip-format\": \"<big>{:%Y %B}</big>\\n<tt><small>{calendar}</small></tt>\",\n        \"calendar\": {\n            \"mode\": \"month\",\n            \"format\": {\n                \"months\": \"<span color='#89b4fa'><b>{}</b></span>\",\n                \"days\": \"<span color='#cdd6f4'>{}</span>\",\n                \"weekdays\": \"<span color='#f9e2af'><b>{}</b></span>\",\n                \"today\": \"<span color='#a6e3a1'><b><u>{}</u></b></span>\"\n            }\n        }\n    },\n    \"mpris\": {\n        \"format\": \"{player_icon} {title} - {artist}\",\n        \"format-paused\": \"{status_icon} {player_icon} {title} - {artist}\",\n        \"format-stopped\": \"\",\n\n        \"player\": \"playerctld\",\n\n        \"player-icons\": {\n            \"default\": \"🎵\",\n            \"firefox\": \"🦊\"\n        },\n        \"status-icons\": {\n            \"playing\": \"▶\",\n            \"paused\": \"⏸\",\n            \"stopped\": \"⏹\"\n        },\n\n        \"max-length\": 500,\n        \"tooltip-format\": \"{player}: {title} - {artist}\\n{album}\"\n    },\n\n    \"battery\": {\n        \"states\": {\n            \"warning\": 30,\n            \"critical\": 15\n        },\n        \"format\": \"{icon} {capacity}%\",\n        \"format-charging\": \" {capacity}%\",\n        \"format-plugged\": \" {capacity}%\",\n        \"format-icons\": [\"\", \"\", \"\", \"\", \"\"]\n    },\n    \n    \"network\": {\n        \"format-wifi\": \" {essid}\",\n        \"format-ethernet\": \" Wired\",\n        \"format-disconnected\": \"⚠ Disconnected\",\n        \"tooltip-format\": \"{ifname}: {ipaddr}/{cidr}\",\n        \"on-click\": \"nm-connection-editor\"\n    },\n    \n    \"pulseaudio\": {\n        \"format\": \"{icon} {volume}%\",\n        \"format-muted\": \" Muted\",\n        \"format-icons\": {\n            \"default\": [\"\", \"\", \"\"]\n        },\n        \"on-click\": \"pavucontrol\"\n    },\n    \n    \"tray\": {\n        \"spacing\": 10\n    },\n    \n    \"idle_inhibitor\": {\n        \"format\": \"{icon}\",\n        \"format-icons\": {\n            \"activated\": \"󰅶\",\n            \"deactivated\": \"󰾪\"\n        },\n        \"tooltip-format-activated\": \"Idle inhibitor active\",\n        \"tooltip-format-deactivated\": \"Idle inhibitor inactive\"\n    },\n    \n    \"group/status\": {\n        \"orientation\": \"horizontal\",\n        \"modules\": [\"idle_inhibitor\", \"cpu\", \"memory\", \"temperature\", \"disk\", \"backlight\", \"pulseaudio\", \"network\", \"battery\", \"tray\"]\n        //(\"modules-right\": [\"mpris\", \"idle_inhibitor\", \"cpu\", \"memory\", \"temperature\", \"disk\", \"backlight\", \"pulseaudio\", \"network\", \"battery\", \"tray\"],\n    \n    },\n    \n    \"cpu\": {\n        \"interval\": 2,\n        \"format\": \"  {usage}%\",\n        \"tooltip\": true,\n        \"tooltip-format\": \"CPU Usage: {usage}%\\nLoad: {load}\"\n    },\n    \n    \"memory\": {\n        \"interval\": 5,\n        \"format\": \"  {percentage}%\",\n        \"tooltip-format\": \"RAM: {used:0.1f}G / {total:0.1f}G\\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G\"\n    },\n    \n    \"temperature\": {\n        \"critical-threshold\": 80,\n        \"format\": \"{icon} {temperatureC}°C\",\n        \"format-icons\": [\"\", \"\", \"\", \"\", \"\"],\n        \"tooltip-format\": \"Temperature: {temperatureC}°C\"\n    },\n    \n    \"disk\": {\n        \"interval\": 30,\n        \"format\": \"  {percentage_used}%\",\n        \"path\": \"/\",\n        \"tooltip-format\": \"Used: {used} / {total}\\nFree: {free} ({percentage_free}%)\"\n    },\n    \n    \"backlight\": {\n        \"device\": \"intel_backlight\",\n        \"format\": \"{icon} {percent}%\",\n        \"format-icons\": [\"󰃞\", \"󰃟\", \"󰃠\"],\n        \"tooltip-format\": \"Brightness: {percent}%\",\n        \"on-scroll-up\": \"brightnessctl set 5%+\",\n        \"on-scroll-down\": \"brightnessctl set 5%-\"\n    },\n}\n","epoch":4,"telemetryInfo":{}}],["file:///home/alex/.config/install.sh::request_73d0954a-ffd1-46f0-9563-8e351388e581",{"uri":{"$mid":1,"fsPath":"/home/alex/.config/install.sh","external":"file:///home/alex/.config/install.sh","path":"/home/alex/.config/install.sh","scheme":"file"},"requestId":"request_73d0954a-ffd1-46f0-9563-8e351388e581","content":"","epoch":9,"telemetryInfo":{}}]],"operations":[{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/alex/.config/waybar/config","external":"file:///home/alex/.config/waybar/config","path":"/home/alex/.config/waybar/config","scheme":"file"},"requestId":"request_1319ee17-e6fb-4c13-851e-b4865a3096fb","epoch":5,"edits":[{"text":"{\n    \"layer\": \"top\",\n    \"position\": \"top\",\n    \"height\": 18,\n    \"spacing\": 0,","range":{"startLineNumber":1,"startColumn":1,"endLineNumber":5,"endColumn":18}}]},{"type":"create","uri":{"$mid":1,"fsPath":"/home/alex/.config/install.sh","external":"file:///home/alex/.config/install.sh","path":"/home/alex/.config/install.sh","scheme":"file"},"requestId":"request_73d0954a-ffd1-46f0-9563-8e351388e581","epoch":8,"initialContent":"","telemetryInfo":{}},{"type":"textEdit","uri":{"$mid":1,"fsPath":"/home/alex/.config/install.sh","external":"file:///home/alex/.config/install.sh","path":"/home/alex/.config/install.sh","scheme":"file"},"requestId":"request_73d0954a-ffd1-46f0-9563-8e351388e581","epoch":10,"edits":[{"text":"#!/bin/bash","range":{"startLineNumber":1,"startColumn":1,"endLi