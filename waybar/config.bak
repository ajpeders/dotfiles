{
    // ============================================
    // General Settings
    // ============================================
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 0,
    "expand-left": true,
    "fixed-center": true,
    
    // ============================================
    // Module Layout
    // ============================================
    "modules-left": ["tray", "hyprland/workspaces", "hyprland/window"],
    "modules-center": ["group/center"],
    "modules-right": ["mpris", "group/status"],

    // ============================================
    // Left Modules
    // ============================================
    "tray": {
        "spacing": 10
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "persistent-workspaces": {
            "*": 5
        }
    },
    
    "hyprland/window": {
        "format": "{title}",
        "icon": true,
        "icon-size": 16,
        "max-length": 500,
        "separate-outputs": true
    },

    // ============================================
    // Center Modules
    // ============================================
    "group/center": {
        "orientation": "horizontal",
        "modules": ["clock", "custom/weather"]
    },
    
    "clock": {
        "interval": 1,
        "format": "{:%a %b %d  %I:%M:%S %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#89b4fa'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'>{}</span>",
                "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
                "today": "<span color='#a6e3a1'><b><u>{}</u></b></span>"
            }
        }
    },

    "custom/weather": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/weather.sh",
        "return-type": "json",
        "interval": 1800
    },

    // ============================================
    // Right Modules - Media
    // ============================================
    "mpris": {
        "format": "{player_icon} {dynamic}",
        "format-paused": "{status_icon} {player_icon} {dynamic}",
        "format-stopped": "",
        "dynamic-order": ["title", "artist"],
        "dynamic-separator": " - ",
        "player": "playerctld",
        "player-icons": {
            "default": "🎵",
            "firefox": "🦊"
        },
        "status-icons": {
            "playing": "▶",
            "paused": "⏸",
            "stopped": "⏹"
        },
        "max-length": 500,
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl stop",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "tooltip-format": "{player}: {title} - {artist}\n{album}"
    },

    // ============================================
    // Right Modules - Status Group
    // ============================================
    "group/status": {
        "orientation": "horizontal",
        "modules": ["idle_inhibitor", "custom/notifications", "cpu", "memory", "disk", "custom/gpu", "backlight", "pulseaudio", "battery"]
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰅶",
            "deactivated": "󰾪"
        },
        "tooltip-format-activated": "Idle inhibitor active",
        "tooltip-format-deactivated": "Idle inhibitor inactive"
    },

    "custom/notifications": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/notifications.sh",
        "interval": 5,
        "on-click": "~/.config/waybar/scripts/notification-menu.sh",
        "on-click-right": "swaync-client -C -sw",
        "tooltip": false
    },

    // ============================================
    // System Monitoring
    // ============================================
    "cpu": {
        "interval": 2,
        "format": "CPU\n  {usage}%",
        "tooltip": true,
        "tooltip-format": "Intel(R) Core(TM) i7-8700K CPU @ 3.70GHz\nUsage: {usage}%\nLoad: {load}"
    },
    
    "memory": {
        "interval": 5,
        "format": "MEM\n  {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },
    
    "disk": {
        "interval": 30,
        "format": "DISK\n  {percentage_used}%",
        "path": "/",
        "tooltip-format": "Used: {used} / {total}\nFree: {free} ({percentage_free}%)"
    },

    "custom/gpu": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/gpu.sh",
        "return-type": "json",
        "interval": 5
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}°C",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "Temperature: {temperatureC}°C"
    },

    // ============================================
    // Hardware Controls
    // ============================================
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "pulseaudio": {
        "format": "VOL\n{icon} {volume}%",
        "format-muted": "VOL\n Muted",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT\n{icon} {capacity}%",
        "format-charging": "BAT\n {capacity}%",
        "format-plugged": "BAT\n {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    // ============================================
    // Network
    // ============================================
    "network": {
        "format-wifi": " {essid}",
        "format-ethernet": " Wired",
        "format-disconnected": "⚠ Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    }
}
